generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  emailVerified       Boolean              @default(false)
  level               String               @default("B1")
  language            String               @default("en")
  createdAt           DateTime             @default(now())
  stripeCustomerId    String?              @unique
  subscriptionId      String?              @unique
  subscriptionStatus  String?
  subscriptionPlan    String?
  subscriptionEnd     DateTime?
  isStudent           Boolean              @default(false)
  trialEndsAt         DateTime?
  referralCode        String?              @unique
  referredBy          String?
  referralsSent       Referral[]           @relation("referralsSent")
  referralsReceived   Referral[]           @relation("referralsReceived")
  writingSubmissions  WritingSubmission[]
  speakingSubmissions SpeakingSubmission[]
  listeningSessions   ListeningSession[]
  chatMessages        ChatMessage[]
  chatSessions        ChatSession[]
  dailyProgress       DailyProgress[]
  otpCodes            OtpCode[]
  sentFriendships     Friendship[]         @relation("sentFriendships")
  receivedFriendships Friendship[]         @relation("receivedFriendships")
  vocabularyProgress  VocabularyProgress[]
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String   @unique
  bonusGranted Boolean @default(false)
  createdAt   DateTime @default(now())
  referrer    User     @relation("referralsSent", fields: [referrerId], references: [id])
  referred    User     @relation("referralsReceived", fields: [referredId], references: [id])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model WritingSubmission {
  id              String   @id @default(cuid())
  userId          String
  taskType        String
  prompt          String
  response        String
  feedback        String
  band            Float
  vocabularyScore Float?   // 0-9 sub-score from AI feedback
  grammarScore    Float?   // 0-9 sub-score from AI feedback
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model SpeakingSubmission {
  id         String   @id @default(cuid())
  userId     String
  transcript String
  feedback   String
  score      Float
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model ListeningSession {
  id        String   @id @default(cuid())
  userId    String
  passage   String
  score     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
}

model ChatMessage {
  id        String       @id @default(cuid())
  userId    String
  sessionId String?
  role      String
  content   String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])
  session   ChatSession? @relation(fields: [sessionId], references: [id])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  user      User     @relation("sentFriendships", fields: [userId], references: [id])
  friend    User     @relation("receivedFriendships", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model DailyProgress {
  id          String   @id @default(cuid())
  userId      String
  date        String
  task1Type   String
  task1Done   Boolean  @default(false)
  task1Mins   Int      @default(0)
  task2Type   String
  task2Done   Boolean  @default(false)
  task2Mins   Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model WritingPrompt {
  id        String   @id @default(cuid())
  level     String   // CEFR level
  taskType  String   // task1 or task2
  prompt    String   // the writing prompt text
  topic     String   @default("general") // topic category for variety
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([level, taskType])
}

model SpeakingTopic {
  id        String   @id @default(cuid())
  level     String   // CEFR level
  topic     String   // the speaking topic/question
  category  String   @default("general") // topic category
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([level])
}

model ListeningContent {
  id        String   @id @default(cuid())
  level     String   // CEFR level: A1, A2, B1, B2, C1, C2
  language  String   @default("en") // interface language for questions
  passage   String   // English passage text
  questions String   // JSON array of questions
  topic     String   @default("general") // topic category
  usedCount Int      @default(0) // track usage for rotation
  createdAt DateTime @default(now())

  @@index([level, language])
}

model VocabularyWord {
  id         String   @id @default(cuid())
  word       String
  definition String
  example    String
  level      String   // CEFR level: A1, A2, B1, B2, C1, C2
  category   String   @default("general")
  usedCount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([word, level, category])
  @@index([level, category])
}

model VocabularyProgress {
  id        String   @id @default(cuid())
  userId    String
  word      String
  definition String
  example   String
  level     String   // CEFR level
  category  String   @default("general")
  mastery   Int      @default(0) // 0=new, 1=learning, 2=reviewing, 3=mastered
  correct   Int      @default(0) // times answered correctly
  incorrect Int      @default(0) // times answered incorrectly
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, word])
  @@index([userId, mastery])
}
